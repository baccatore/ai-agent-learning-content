---
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
  title: string;
  lang: 'ja' | 'en';
}

const { title, lang } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content="非エンジニアのためのClaude Code活用学習コンテンツ / AI Agent Learning Content for Non-Engineers" />
  <ViewTransitions />
</head>
<body>
  <Header lang={lang} />
  <slot />
</body>
</html>
